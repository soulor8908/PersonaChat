.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 30rpx;
}

.section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.section-header {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 24rpx;
}

.model-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.model-item:last-of-type {
  border-bottom: none;
}

.model-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.model-name {
  font-size: 28rpx;
  color: #333;
}

.model-badge {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.model-badge.free {
  background: #e8f5e9;
  color: #4caf50;
}

.model-badge.paid {
  background: #fff3e0;
  color: #ff9800;
}

.model-badge.custom {
  background: #f3e5f5;
  color: #9c27b0;
}

.model-status {
  font-size: 24rpx;
  color: #999;
}

.model-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 12rpx;
}

.action-btn.delete {
  color: #f44336;
  background: #ffebee;
}

.add-model-btn {
  text-align: center;
  padding: 24rpx;
  color: #667eea;
  font-size: 28rpx;
  border: 2rpx dashed #667eea;
  border-radius: 12rpx;
  margin-top: 20rpx;
}

/* API Key */
.save-btn {
  display: inline-block;
  padding: 12rpx 40rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  border-radius: 12rpx;
  font-size: 26rpx;
  margin-top: 12rpx;
}

.form-hint {
  font-size: 22rpx;
  color: #999;
  margin-top: 12rpx;
}

.about-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
}

/* 弹窗样式 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
}

.modal-content {
  position: relative;
  width: 80%;
  margin: 200rpx auto;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 30rpx;
  text-align: center;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  padding: 16rpx 20rpx;
  border: 1rpx solid #ddd;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.modal-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.modal-btn.cancel {
  background: #f5f5f5;
  color: #666;
}

.modal-btn.confirm {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
}
