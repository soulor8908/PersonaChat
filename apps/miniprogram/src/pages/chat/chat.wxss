.chat-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f5f5;
}

.chat-header {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.header-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.header-info {
  flex: 1;
  margin-left: 20rpx;
  overflow: hidden;
}

.header-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.header-desc {
  font-size: 22rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.header-actions {
  flex-shrink: 0;
}

.model-btn {
  font-size: 24rpx;
  color: #667eea;
  padding: 8rpx 20rpx;
  border: 1rpx solid #667eea;
  border-radius: 20rpx;
}

.message-list {
  flex: 1;
  padding: 20rpx;
  overflow-y: auto;
}

.message {
  display: flex;
  align-items: flex-start;
  margin-bottom: 30rpx;
}

.message-user {
  flex-direction: row-reverse;
}

.msg-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
}

.message-ai .msg-avatar {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
}

.msg-content {
  max-width: 70%;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-all;
}

.message-user .msg-content {
  background: #667eea;
  color: #fff;
  margin-right: 16rpx;
  border-bottom-right-radius: 4rpx;
}

.message-ai .msg-content {
  background: #fff;
  color: #333;
  margin-left: 16rpx;
  border-bottom-left-radius: 4rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.typing text {
  animation: blink 1s infinite;
}

@keyframes blink {
  0%, 100% { opacity: 0.3; }
  50% { opacity: 1; }
}

.input-bar {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
}

.upload-btn {
  font-size: 40rpx;
  padding: 0 16rpx;
  flex-shrink: 0;
}

.input-field {
  flex: 1;
  background: #f5f5f5;
  border-radius: 36rpx;
  padding: 16rpx 30rpx;
  font-size: 28rpx;
}

.send-btn {
  margin-left: 16rpx;
  padding: 16rpx 30rpx;
  background: #ccc;
  color: #fff;
  border-radius: 36rpx;
  font-size: 28rpx;
  flex-shrink: 0;
}

.send-btn.active {
  background: linear-gradient(135deg, #667eea, #764ba2);
}
