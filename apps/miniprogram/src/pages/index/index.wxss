.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 搜索栏 */
.search-bar {
  margin-bottom: 16rpx;
}

.search-input {
  background: #fff;
  border-radius: 40rpx;
  padding: 16rpx 30rpx;
  font-size: 28rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

/* 创建入口 */
.create-entry {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  text-align: center;
  padding: 18rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

/* 热门推荐 */
.hot-section {
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.hot-scroll {
  white-space: nowrap;
  padding-bottom: 8rpx;
}

.hot-card {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 200rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  margin-right: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.hot-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.hot-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}

.hot-meta {
  font-size: 20rpx;
  color: #999;
}

/* 分类标签 */
.category-scroll {
  white-space: nowrap;
  margin-bottom: 12rpx;
}

.category-tag {
  display: inline-block;
  padding: 12rpx 30rpx;
  margin-right: 16rpx;
  border-radius: 30rpx;
  background: #fff;
  font-size: 26rpx;
  color: #666;
}

.category-tag.active {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
}

/* 排序 */
.sort-bar {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.sort-btn {
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #666;
  background: #fff;
}

.sort-btn.active {
  color: #667eea;
  background: #f0f0ff;
}

/* 人格卡片 */
.persona-card {
  display: flex;
  align-items: flex-start;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.persona-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.persona-info {
  margin-left: 24rpx;
  flex: 1;
  overflow: hidden;
}

.persona-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.persona-desc {
  font-size: 24rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 8rpx;
}

.persona-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.persona-category {
  font-size: 22rpx;
  color: #667eea;
  background: #f0f0ff;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.persona-stars {
  font-size: 22rpx;
  color: #999;
}

.persona-stats {
  display: flex;
  gap: 20rpx;
  font-size: 22rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
  opacity: 0.4;
}

/* 骨架屏 */
.loading-skeleton {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.skeleton-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

.skeleton-text {
  font-size: 28rpx;
  color: #999;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
